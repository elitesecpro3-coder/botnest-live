{
  "name": "botnest-monorepo",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/widget",
    "apps/admin"
  ],
  "scripts": {
    "build": "npm run build --workspace apps/widget && npm run build --workspace apps/api",
    "start": "node apps/api/dist/server.js",
    "dev:api": "pnpm --filter api dev",
    "dev:widget": "pnpm --filter widget dev",
    "dev:admin": "pnpm --filter admin dev"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "pnpm": "^8.0.0"
  }
}
